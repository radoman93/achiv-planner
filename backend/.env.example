# --- PostgreSQL ---
# Credentials used by the postgres service and by the backend ORM URL
POSTGRES_USER=wow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wow_optimizer
# Async SQLAlchemy connection string
DATABASE_URL=postgresql+asyncpg://wow:change-me@postgres:5432/wow_optimizer

# --- Redis (Celery broker + cache) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT auth ---
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# --- Battle.net OAuth2 ---
BATTLENET_CLIENT_ID=
BATTLENET_CLIENT_SECRET=
BATTLENET_REDIRECT_URI=https://example.com/api/auth/battlenet/callback

# --- Anthropic Claude API ---
# Create key at console.anthropic.com. Set a $25 monthly spend cap there
# BEFORE flipping LLM_ENRICHMENT_ENABLED to true. That console cap is the
# hard ceiling; everything below is defense in depth.
ANTHROPIC_API_KEY=

# Master switch. Defaults false so a misconfigured deploy never spends money.
LLM_ENRICHMENT_ENABLED=false

# Mode gate: live | dry_run | sample
#   dry_run = log prompt + estimated tokens, make NO API calls
#   sample  = only call API for achievements whose blizzard_id is in LLM_SAMPLE_IDS
#   live    = normal operation (still gated by ENABLED + budget + kill switch)
LLM_ENRICHMENT_MODE=dry_run
LLM_SAMPLE_IDS=1,6,45,500,1000

# Model routing — Haiku by default, Sonnet only for multi-source / long inputs.
LLM_DEFAULT_MODEL=claude-haiku-4-5-20241022
LLM_COMPLEX_MODEL=claude-sonnet-4-5-20241022

# Spend ceilings tracked in Redis (pipeline/llm_budget.py).
# Workers short-circuit once lifetime spend >= LLM_BUDGET_HARD_STOP_USD.
# The $5 gap to LLM_MONTHLY_BUDGET_USD absorbs concurrent-worker overshoot.
LLM_MONTHLY_BUDGET_USD=25.0
LLM_BUDGET_HARD_STOP_USD=20.0

# Route bulk enrichment through Batch API (50% discount) at this queue size.
LLM_BATCH_MIN_SIZE=20

# Output cap. Observed enrichment output is ~400-500 tokens.
LLM_MAX_OUTPUT_TOKENS=800

# Emergency kill switch (set at runtime, not in .env):
#   redis-cli set llm:kill_switch 1
# All workers stop dispatching Claude calls on the next check.

# --- Raw scraped content ---
# Filesystem path inside backend + celery containers
RAW_STORAGE_PATH=/raw_storage

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO

# --- Flower dashboard (basic auth) ---
FLOWER_USER=admin
FLOWER_PASSWORD=change-me

# --- App ---
ENVIRONMENT=development
