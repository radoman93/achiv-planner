# ==============================================================================
# Backend environment configuration
# ==============================================================================
# Copy to `backend/.env` and fill in the real values. Never commit .env.
# Generate secrets with: python -c "import secrets; print(secrets.token_hex(32))"

# === DATABASE =================================================================
POSTGRES_USER=wow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wow_optimizer
# Async SQLAlchemy connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://wow:change-me@postgres:5432/wow_optimizer

# === REDIS ====================================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === SECURITY =================================================================
# Minimum 32 characters. Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-32-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === BATTLE.NET OAUTH2 ========================================================
# Register at https://develop.battle.net/
BATTLENET_CLIENT_ID=
BATTLENET_CLIENT_SECRET=
BATTLENET_REDIRECT_URI=https://yourdomain.com/api/auth/battlenet/callback

# === ANTHROPIC CLAUDE API =====================================================
# Create key at console.anthropic.com. Set a $25/mo spend cap THERE before
# enabling LLM enrichment. Key must start with `sk-ant-`.
ANTHROPIC_API_KEY=

# OpenRouter fallback (optional)
OPENROUTER_API_KEY=

# Master switch. Defaults false so a misconfigured deploy never spends money.
LLM_ENRICHMENT_ENABLED=false

# Mode gate: live | dry_run | sample
LLM_ENRICHMENT_MODE=dry_run
LLM_SAMPLE_IDS=1,6,45,500,1000

# Model routing
LLM_DEFAULT_MODEL=claude-haiku-4-5-20251001
LLM_COMPLEX_MODEL=claude-haiku-4-5-20251001

# Spend ceilings (Redis-tracked, enforced by pipeline/llm_budget.py).
LLM_MONTHLY_BUDGET_USD=25.0
LLM_BUDGET_HARD_STOP_USD=20.0

# Route bulk enrichment through Batch API (50% discount) at this queue size.
LLM_BATCH_MIN_SIZE=20

# Output cap. Observed enrichment output is ~400-500 tokens.
LLM_MAX_OUTPUT_TOKENS=800

# Emergency kill switch (set at runtime, NOT in .env):
#   redis-cli set llm:kill_switch 1

# === YOUTUBE API (OPTIONAL) ===================================================
# Get from https://console.cloud.google.com/. When empty, YouTube fallback
# scraping is disabled — the app logs a warning at startup and continues.
YOUTUBE_API_KEY=

# === FRONTEND =================================================================
# The public URL the frontend is served from. Used as the CORS allowlist anchor
# in production. In development, localhost:3000/3001 are also allowed.
FRONTEND_URL=https://yourdomain.com

# === STORAGE ==================================================================
# Filesystem path inside backend + celery containers
RAW_STORAGE_PATH=/raw_storage

# === MONITORING ===============================================================
# Leave empty to disable Sentry integration entirely
SENTRY_DSN=
LOG_LEVEL=INFO

# === FLOWER DASHBOARD =========================================================
FLOWER_USER=admin
FLOWER_PASSWORD=change-this-password

# === APP ======================================================================
# 'development' or 'production' — controls log format, CORS allow-list,
# and DB SSL handling.
ENVIRONMENT=production
